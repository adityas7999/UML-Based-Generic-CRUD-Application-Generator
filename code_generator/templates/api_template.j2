@app.route('/{{ class_name|lower }}', methods=['POST'])
def create_{{ class_name|lower }}_api():
    """
    Create a new {{ class_name }}
    ---
    tags:
      - {{ class_name }}
    parameters:
      - in: body
        name: body
        required: true
        schema:
          id: {{ class_name }}
          required:
            {% for attr in attributes %}
            - {{ attr.name }}
            {% endfor %}
          properties:
            {% for attr in attributes %}
            {{ attr.name }}:
              type: string
            {% endfor %}
    responses:
      201:
        description: {{ class_name }} created successfully
      400:
        description: Bad Request - Missing fields
      500:
        description: Internal Server Error
    """
    data = request.get_json()
    
    # 1. Bulletproof Error Handling: Dynamic Missing Field Check
    required_fields = [{% for attr in attributes %}'{{ attr.name }}'{% if not loop.last %}, {% endif %}{% endfor %}]
    missing = [f for f in required_fields if f not in data]
    if missing:
        return jsonify({"error": f"Bad Request. Missing required fields: {', '.join(missing)}"}), 400

    try:
        create_{{ class_name|lower }}(data)
        return jsonify({"message": "{{ class_name }} created successfully"}), 201
    except Exception as e:
        return jsonify({"error": f"Database error: {str(e)}"}), 500


