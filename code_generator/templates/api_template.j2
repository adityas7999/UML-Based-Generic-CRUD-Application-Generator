from flask import Flask, request, jsonify
from flasgger import Swagger
import repository as repo

app = Flask(__name__)

# Swagger Setup
swagger = Swagger(app, template={
    "info": {
        "title": "Auto-Generated MDE API",
        "description": "REST API generated from UML Class Diagram",
        "version": "1.0.0"
    }
})

{% for cls in classes %}
# ==========================================
# {{ cls.name }} API Endpoints
# ==========================================

@app.route('/{{ cls.name|lower }}', methods=['POST'])
def create_{{ cls.name|lower }}():
    """
    Create {{ cls.name }}
    ---
    tags:
      - {{ cls.name }}
    parameters:
      - name: body
        in: body
        required: true
        schema:
          type: object
          required:
            {% for attr in cls.insert_attributes %}
            - {{ attr.name }}
            {% endfor %}
          properties:
            {% for attr in cls.insert_attributes %}
            {{ attr.name }}:
              type: {{ 'integer' if 'int' in attr.type|lower else 'string' }}
            {% endfor %}
          example:
            {% for attr in cls.insert_attributes %}
            {{ attr.name }}: {{ 0 if 'int' in attr.type|lower else '"string"' }}
            {% endfor %}
    responses:
      201:
        description: Created successfully
      400:
        description: Missing fields
      500:
        description: Server error
    """
    data = request.get_json(silent=True)

    if not data:
        return jsonify({"error": "Request body must be valid JSON"}), 400

    required_fields = [{%- for attr in cls.insert_attributes -%}"{{ attr.name }}"{%- if not loop.last %}, {% endif -%}{%- endfor -%}]
    missing = [f for f in required_fields if f not in data]

    if missing:
        return jsonify({"error": f"Missing fields: {', '.join(missing)}"}), 400

    try:
        success = repo.insert_{{ cls.name|lower }}(
            {%- for attr in cls.insert_attributes %}
            data.get("{{ attr.name }}"){%- if not loop.last %}, {% endif %}
            {%- endfor %}
        )

        if success:
            return jsonify({"message": "{{ cls.name }} created"}), 201
        return jsonify({"error": "Insert failed"}), 500

    except Exception as e:
        return jsonify({"error": str(e)}), 500


@app.route('/{{ cls.name|lower }}', methods=['GET'])
def get_all_{{ cls.name|lower }}():
    """
    Get all {{ cls.name }}
    ---
    tags:
      - {{ cls.name }}
    responses:
      200:
        description: List of {{ cls.name }}
      500:
        description: Server error
    """
    try:
        data = repo.get_all_{{ cls.name|lower }}()
        return jsonify(data or []), 200
    except Exception as e:
        return jsonify({"error": str(e)}), 500


@app.route('/{{ cls.name|lower }}/<string:{{ cls.pk_name }}>', methods=['GET'])
def get_{{ cls.name|lower }}({{ cls.pk_name }}):
    """
    Get {{ cls.name }} by {{ cls.pk_name }}
    ---
    tags:
      - {{ cls.name }}
    parameters:
      - name: {{ cls.pk_name }}
        in: path
        type: string
        required: true
    responses:
      200:
        description: Record found
      404:
        description: Not found
    """
    try:
        data = repo.get_{{ cls.name|lower }}_by_{{ cls.pk_name | lower }}({{ cls.pk_name }})
        if data:
            return jsonify(data), 200
        return jsonify({"error": "{{ cls.name }} not found"}), 404
    except Exception as e:
        return jsonify({"error": str(e)}), 500


@app.route('/{{ cls.name|lower }}/<string:{{ cls.pk_name }}>', methods=['PUT'])
def update_{{ cls.name|lower }}({{ cls.pk_name }}):
    """
    Update {{ cls.name }}
    ---
    tags:
      - {{ cls.name }}
    parameters:
      - name: {{ cls.pk_name }}
        in: path
        type: string
        required: true
      - name: body
        in: body
        required: true
        schema:
          type: object
          required:
            {% for attr in cls.update_attributes %}
            - {{ attr.name }}
            {% endfor %}
          properties:
            {% for attr in cls.update_attributes %}
            {{ attr.name }}:
              type: {{ 'integer' if 'int' in attr.type|lower else 'string' }}
            {% endfor %}
          example:
            {% for attr in cls.update_attributes %}
            {{ attr.name }}: {{ 0 if 'int' in attr.type|lower else '"string"' }}
            {% endfor %}
    responses:
      200:
        description: Updated successfully
      400:
        description: Invalid input
      500:
        description: Server error
    """
    data = request.get_json(silent=True)

    if not data:
        return jsonify({"error": "No update data provided"}), 400

    try:
        success = repo.update_{{ cls.name|lower }}(
            {{ cls.pk_name }}
            {%- if cls.update_attributes -%},{%- endif %}
            {%- for attr in cls.update_attributes %}
            data.get("{{ attr.name }}"){%- if not loop.last %}, {% endif %}
            {%- endfor %}
        )

        if success:
            return jsonify({"message": "{{ cls.name }} updated"}), 200
        return jsonify({"error": "Update failed"}), 500

    except Exception as e:
        return jsonify({"error": str(e)}), 500


@app.route('/{{ cls.name|lower }}/<string:{{ cls.pk_name }}>', methods=['DELETE'])
def delete_{{ cls.name|lower }}({{ cls.pk_name }}):
    """
    Delete {{ cls.name }}
    ---
    tags:
      - {{ cls.name }}
    parameters:
      - name: {{ cls.pk_name }}
        in: path
        type: string
        required: true
    responses:
      200:
        description: Deleted successfully
      500:
        description: Server error
    """
    try:
        success = repo.delete_{{ cls.name|lower }}({{ cls.pk_name }})

        if success:
            return jsonify({"message": "{{ cls.name }} deleted"}), 200
        return jsonify({"error": "Delete failed"}), 500

    except Exception as e:
        return jsonify({"error": str(e)}), 500

{% endfor %}

if __name__ == "__main__":
    app.run(debug=True)