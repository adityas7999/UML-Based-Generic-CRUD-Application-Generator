"""
Central Database Configuration
All database operations in the application use connections from this module.
This centralizes connection management and prevents duplication across layers.
"""

import os
import mysql.connector

def get_connection():
    """
    Get a fresh MySQL database connection using environment variables for security.
    """
    return mysql.connector.connect(
        host=os.getenv("DB_HOST", "localhost"),
        user=os.getenv("DB_USER", "root"),
        password=os.getenv("DB_PASSWORD", "YOUR_DB_PASSWORD_HERE"),  # Secure placeholder
        database=os.getenv("DB_NAME", "uml_crud_db")
    )